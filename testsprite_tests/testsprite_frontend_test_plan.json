  {
    "id": "TC008",
    "title": "Evaluate a high target-ratio trade and display AI roast inline",
    "description": "Verifies that evaluating a trade with an extreme target ratio shows an AI roast result in the UI for that trade.",
    "category": "AI Risk Evaluator (Roast)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /journal"
      },
      {
        "type": "assertion",
        "description": "Verify page title contains \"Journal\""
      },
      {
        "type": "action",
        "description": "Scroll to a saved trade showing Target Ratio set to \"15\""
      },
      {
        "type": "action",
        "description": "Click Evaluate Button (btn-evaluate) on that trade"
      },
      {
        "type": "assertion",
        "description": "Verify text \"greedy dreamers\" is visible within the evaluation result area for that same trade"
      },
      {
        "type": "assertion",
        "description": "Verify element \"AI evaluation result\" is visible for that same trade"
      }
    ]
  },
  {
    "id": "TC009",
    "title": "Evaluate button behavior when there are no saved trades",
    "description": "Verifies the UI prevents evaluation when the journal has no saved trades by showing a message or disabling evaluation.",
    "category": "AI Risk Evaluator (Roast)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /journal"
      },
      {
        "type": "assertion",
        "description": "Verify text \"No trades to evaluate\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify element \"Evaluate Button (btn-evaluate)\" is not visible"
      }
    ]
  },
  {
    "id": "TC010",
    "title": "Repeated evaluation does not create duplicate visible results for the same trade",
    "description": "Verifies that clicking Evaluate multiple times on the same trade does not show multiple stacked/duplicated roast outputs.",
    "category": "AI Risk Evaluator (Roast)",
    "priority": "Medium",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /journal"
      },
      {
        "type": "action",
        "description": "Scroll to a saved trade"
      },
      {
        "type": "action",
        "description": "Click Evaluate Button (btn-evaluate) on that trade"
      },
      {
        "type": "assertion",
        "description": "Verify element \"AI evaluation result\" is visible for that trade"
      },
      {
        "type": "action",
        "description": "Click Evaluate Button (btn-evaluate) on that same trade again"
      },
      {
        "type": "assertion",
        "description": "Verify text \"greedy dreamers\" is visible within the evaluation result area for that same trade"
      }
    ]
  },
  {
    "id": "TC011",
    "title": "Evaluation result stays associated with the correct trade when multiple trades exist",
    "description": "Verifies the roast output renders inline on the trade that was evaluated and not on a different trade row/card.",
    "category": "AI Risk Evaluator (Roast)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /journal"
      },
      {
        "type": "action",
        "description": "Scroll to a saved trade showing Target Ratio set to \"15\""
      },
      {
        "type": "action",
        "description": "Click Evaluate Button (btn-evaluate) on that trade"
      },
      {
        "type": "assertion",
        "description": "Verify text \"greedy dreamers\" is visible within the evaluation result area for that trade"
      },
      {
        "type": "action",
        "description": "Scroll to a different saved trade (one that is not the evaluated trade)"
      },
      {
        "type": "assertion",
        "description": "Verify element \"AI evaluation result\" is not visible for the different trade"
      }
    ]
  },
