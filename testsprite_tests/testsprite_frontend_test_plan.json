    "id": "TC001",
    "title": "Calculate target profit updates when inputs are valid and target ratio changes",
    "description": "Verifies that entering valid risk parameters updates Target Profit to the expected value when Target Ratio is modified.",
    "category": "Risk Calculation",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /"
      },
      {
        "type": "action",
        "description": "Fill \"Capital\" input with \"10000\""
      },
      {
        "type": "action",
        "description": "Fill \"Risk %\" input with \"1\""
      },
      {
        "type": "action",
        "description": "Fill \"Entry Price\" input with \"100\""
      },
      {
        "type": "action",
        "description": "Fill \"Stop Loss\" input with \"90\""
      },
      {
        "type": "action",
        "description": "Fill \"Target Ratio (1:X)\" input with \"4\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"400\" is visible in the Target Profit result"
      }
    ]
  },
